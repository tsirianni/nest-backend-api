# App generals
NODE_ENV=development
API_DOMAIN=localhost
API_PORT=4000
ALLOWED_ORIGINS=http://localhost:3000
ACCESS_TOKEN_EXPIRATION_TIME=5m
REFRESH_TOKEN_EXPIRATION_TIME=10m

# Encryption
UUID_CIPHER_ALGORITHM=something
UUID_CIPHER_KEY=3253658ba35a6bb5d3429c357b4b8857e61340243a3855f74cd65ccd22a3ffc2

# SMTP Config
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourEmailAddressHere
SMTP_PASSWORD=yourGmailAppKeyHere
SMTP_FROM=yourEmailAddressHere

# Database
DATABASE_URL="postgresql://postgres:postgres@pg-database:5432/BackendAPI?schema=public"
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=BackendAPI

# JWT Secret
JWT_PUBLIC_KEY=yourPublicKeyHere
JWT_PRIVATE_KEY=yourPrivateKeyHere

# Bcrypt
BCRYPT_ROUNDS=12

# AWS
AWS_ACCESS_KEY_ID=yourKeyIdHere
AWS_SECRET_ACCESS_KEY=yourSecretKeyHere
AWS_REGION=yourRegionHere
AWS_ATTACHMENTS_BUCKET=yourBucketNameHere