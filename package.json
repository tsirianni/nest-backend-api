{
  "name": "nest-backend-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "docker compose up -d && docker logs -f api",
    "stop": "docker compose down",
    "start:debug": "nest start --debug 0.0.0.0:9229 --watch",
    "start:prod": "node dist/main",
    "lint": "eslint ./src",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch --config jest.config.js",
    "test:cov": "jest --coverage --config jest.config.js",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand --config jest.config.js",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:unit:ci": "jest --ci --config jest.config.js",
    "husky:init": "npx husky init",
    "prepare": "husky",
    "pre-commit-lint": "lint-staged",
    "lint-staged-files": "eslint --fix",
    "format-staged-files": "prettier --write",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "rebase:origin": "git fetch && git rebase origin/main"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/lib-storage": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.777.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^11.1.0",
    "@prisma/client": "^5.15.0",
    "@types/luxon": "^3.4.2",
    "@types/nodemailer": "^6.4.15",
    "axios": "^1.8.3",
    "bcrypt": "^5.1.1",
    "bignumber.js": "^9.1.2",
    "busboy": "^1.6.0",
    "cookie-parser": "^1.4.6",
    "helmet": "^8.1.0",
    "luxon": "^3.4.4",
    "nodemailer": "^6.9.13",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "uuid": "^11.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@jest-mock/express": "^3.0.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/axios": "^0.14.0",
    "@types/bcrypt": "^5.0.2",
    "@types/busboy": "^1.5.4",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.0",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "lint-staged": "^15.2.5",
    "prettier": "^3.0.0",
    "prisma": "^5.15.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.4.0"
  }
}
